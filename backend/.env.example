# 环境变量配置
# 复制此文件为 .env 并填入真实值

# DeepSeek API Key (用于测试)
DEEPSEEK_API_KEY=sk-your-key-here

# ── 渠道说明 ───────────────────────────────────────────────
# 渠道 1：内部自建，支持高峰/非高峰切换，有每日限额
#   KEY/URL/NAME 对应非高峰模型，NAME_PEAK 对应高峰时段（16:00-24:00 北京时间）
DEFAULT_FREE_MODEL_KEY=sk-free-model-key-here
DEFAULT_FREE_MODEL_URL=https://your-internal-endpoint/v1
DEFAULT_FREE_MODEL_NAME=your-model-name
DEFAULT_FREE_MODEL_NAME_PEAK=your-peak-model-name

# 渠道 2、5：内部自建，有每日限额
#   KEY2/URL2 共用；NAME2 → 渠道2，NAME5 → 渠道5
DEFAULT_FREE_MODEL_KEY2=sk-your-key-here
DEFAULT_FREE_MODEL_URL2=http://your-internal-endpoint/v1
DEFAULT_FREE_MODEL_NAME2=deepseek-v3-2-251201
DEFAULT_FREE_MODEL_NAME5=doubao-seed-2-0-mini-260215

# 渠道 3、4：OpenRouter 免费渠道，无每日限额，但会做可用性检查（启动时+每3小时）
#   不可用时两者互相 fallback；KEY3 是 OpenRouter API Key（sk-or-v1-...）
#   URL 必须是 base URL（https://openrouter.ai/api/v1），不要填 /chat/completions
DEFAULT_FREE_MODEL_KEY3=sk-or-v1-your-openrouter-key-here
DEFAULT_FREE_MODEL_URL3=https://openrouter.ai/api/v1
DEFAULT_FREE_MODEL_NAME3=qwen/qwen3.6-plus:free
DEFAULT_FREE_MODEL_NAME4=stepfun/step-3.5-flash:free

# PostgreSQL 数据库完整连接 URL
PG_URL=postgresql://postgres:[YOUR_PASSWORD]@db.12345.supabase.co:5432/postgres

# Agent 最大迭代次数；达到上限后禁用工具，将已有工具结果交给模型生成最终回答
AGENT_MAX_ITERATIONS=15